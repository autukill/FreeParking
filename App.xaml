<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreeParkingMaui"
             xmlns:converters="clr-namespace:FreeParkingMaui.Converters"
             x:Class="FreeParkingMaui.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
            <converters:BoolToStatusTextConverter x:Key="BoolToStatusTextConverter"/>
            <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <!-- Add other converters if needed -->
            
        </ResourceDictionary>
    </Application.Resources>
</Application>
