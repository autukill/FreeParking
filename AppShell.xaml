<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FreeParkingMaui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FreeParkingMaui"
    xmlns:views="clr-namespace:FreeParkingMaui.Views"
    Title="FreeParkingMaui">

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage" />

    <ShellContent
        Title="Monitor"
        ContentTemplate="{DataTemplate views:MainPage}"
        Route="MainPage" />

</Shell>
